# .env.example — コピーして .env を作成してください
# cp .env.example .env

# J-Quants API キー（J-Quantsのマイページから取得）
JQUANTS_API_KEY=your_jquants_api_key_here

# ログレベル（INFO / DEBUG / WARN）
LOG_LEVEL=INFO

# フロントエンドAPIベースURL
# 同一WiFiの別端末からアクセスする場合はホストマシンのIPアドレスに変更
# 例: VITE_API_BASE_URL=http://192.168.1.10:8080
VITE_API_BASE_URL=http://localhost:8080
